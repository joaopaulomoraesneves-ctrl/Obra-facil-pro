# Obra Fácil Pro — variáveis futuras de nuvem

# Copie este arquivo para .env.local quando for usar Supabase.
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-publica

# Modo atual recomendado:
# local = mantém funcionamento no navegador/localStorage
# supabase = futuro modo com banco em nuvem
VITE_OBRA_FACIL_STORAGE_MODE=local
